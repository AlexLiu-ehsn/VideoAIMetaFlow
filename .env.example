# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/videometa
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=videometa

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
STORAGE_PATH=./storage
MAX_CONCURRENT_ANALYSIS=2
